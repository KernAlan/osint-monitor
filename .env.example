# OSINT Monitor Environment Configuration
# Copy this to .env and fill in your values

# ── LLM Providers ──────────────────────────────────────
# Default provider (openai, anthropic, ollama, gemini)
OSINT_DEFAULT_LLM_PROVIDER=openai

# OpenAI (required for briefings, CIR reports, ACH)
OPENAI_API_KEY=your-openai-api-key-here
OSINT_OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# ANTHROPIC_API_KEY=your-anthropic-key

# Ollama (optional, for local LLM)
# OSINT_OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini (optional)
# GOOGLE_API_KEY=your-google-key

# ── Social Media ───────────────────────────────────────
# Twitter API v2 (optional, falls back to Nitter)
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Telegram (optional)
# TELEGRAM_API_ID=your-api-id
# TELEGRAM_API_HASH=your-api-hash

# ── Intelligence Source APIs ───────────────────────────
# All optional. Collectors degrade gracefully without keys.
# Free keys - apply at the URLs shown.

# US Congress legislation tracking
# Apply: https://api.congress.gov/sign-up/
# CONGRESS_API_KEY=your-congress-api-key

# FAA NOTAM airspace closures
# Apply: https://api.faa.gov/s/
# FAA_NOTAM_KEY=your-faa-notam-key

# NASA FIRMS fire/thermal detection (has public fallback without key)
# Apply: https://firms.modaps.eosdis.nasa.gov/api/area/
# NASA_FIRMS_KEY=your-nasa-firms-key

# NVD vulnerability database (increases rate limit from 5 to 50 req/30s)
# Apply: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your-nvd-api-key

# Copernicus Sentinel Hub satellite imagery
# Apply: https://dataspace.copernicus.eu/ -> Account Settings -> OAuth clients
# SENTINEL_CLIENT_ID=sh-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# SENTINEL_CLIENT_SECRET=your-client-secret
# Legacy static token (auto-refresh via client credentials is preferred):
# SENTINEL_HUB_TOKEN=your-sentinel-hub-token

# UN COMTRADE trade flow data
# Apply: https://comtradeapi.un.org/
# COMTRADE_API_KEY=your-comtrade-key

# ── Infrastructure ─────────────────────────────────────
# Database (default: SQLite, supports PostgreSQL+pgvector)
# OSINT_DB_URL=sqlite:///data/osint.db
# OSINT_DB_URL=postgresql://osint:osint_dev@localhost:5432/osint_monitor

# Celery task queue (optional, requires Redis)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# spaCy model (default: en_core_web_lg)
# OSINT_SPACY_MODEL=en_core_web_lg

# API server
# OSINT_API_HOST=0.0.0.0
# OSINT_API_PORT=8000

# API key authentication (if set, requires X-API-Key header on /api/ routes)
# OSINT_API_KEY=your-secret-api-key
